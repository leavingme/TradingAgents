# =============================================================
# TradingAgents 环境变量配置模板
# 复制此文件为 .env 并填写对应值
# =============================================================

# --- 自定义接口（Custom Provider）---
# 适用于兼容 OpenAI 格式的本地网关或第三方代理
OPENAI_API_BASE=http://127.0.0.1:4000/v1
OPENAI_API_KEY=your_api_key_here

# 自定义接口默认模型（CLI 选 Custom 时预填，可按 Enter 接受）
CUSTOM_QUICK_MODEL=kimi-code
CUSTOM_DEEP_MODEL=kimi-code

# --- 云端 LLM 供应商（按需填写其中一项）---
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
# ANTHROPIC_API_KEY=sk-ant-...
# XAI_API_KEY=xai-...
# OPENROUTER_API_KEY=sk-or-...

# --- 长桥 (Longbridge) 行情 API ---
# 在 https://open.longportapp.com 申请
# Access Token 有效期约 30 天，到期需重新获取
LONGBRIDGE_APP_KEY=your_app_key
LONGBRIDGE_APP_SECRET=your_app_secret
LONGBRIDGE_ACCESS_TOKEN=your_access_token

# --- 财务数据 ---
# Alpha Vantage（基本面/新闻备用数据源）
# 免费 Key 在 https://www.alphavantage.co/support/#api-key 申请
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# --- 结果存储目录 ---
TRADINGAGENTS_RESULTS_DIR=./results
